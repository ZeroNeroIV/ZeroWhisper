# JWT — CHANGE THIS before first run
JWT_SECRET=generate-a-random-32-char-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DB_PATH=data/zerowhisper.db
SETUP_STATE_PATH=data/setup_state.json

# OpenAI — required for Whisper agent
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=gpt-4o-mini

# Exchange rates
AUTO_FETCH_EXCHANGE_RATE=false
DEFAULT_EXCHANGE_RATE=0.709

# Logging
LOG_LEVEL=INFO
