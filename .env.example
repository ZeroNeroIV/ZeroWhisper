# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-32-random-chars

# Optional — OpenAI Whisper NL2A agent
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=gpt-4o-mini

# Optional — exchange rate (set AUTO_FETCH=true and add API key if desired)
AUTO_FETCH_EXCHANGE_RATE=false
DEFAULT_EXCHANGE_RATE=0.709

# Optional
LOG_LEVEL=INFO
