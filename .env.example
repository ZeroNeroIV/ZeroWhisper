# ZeroWhisper Configuration

# Required: OpenAI API key for the Whisper agent
OPENAI_API_KEY=sk-...

# Optional: OpenAI base URL (default: OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: OpenAI model for Whisper (default: gpt-4o-mini)
WHISPER_MODEL=gpt-4o-mini

# Security: JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-32-random-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database path (relative to backend working directory)
DB_PATH=data/zerowhisper.db
SETUP_STATE_PATH=data/setup_state.json

# Exchange rates: set to true to auto-fetch from Frankfurter API
AUTO_FETCH_EXCHANGE_RATE=false
DEFAULT_EXCHANGE_RATE=0.709

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
